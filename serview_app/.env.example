# Firebase client config — powers Analytics AND the CMS (Firestore, Auth, Storage).
# Copy this file to `.env.local` and paste the values from your Firebase console:
#   Firebase console → Project settings → General → Your apps → Web app → SDK config.
# These values ship to the browser by design (they are not secrets); keeping them
# in .env.local just avoids committing project-specific config.
#
# apiKey + projectId are the minimum needed for Firestore/Auth/Storage. Without
# them, services/testimonials fall back to bundled seed content and the /admin
# CMS can't sign in. measurementId is optional (analytics-only; off when unset).
# The GitHub Pages deploy passes these as repo secrets (see deploy.yml).

VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_FB_MEASUREMENT_ID=
