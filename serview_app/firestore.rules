rules_version = '2';

// =============================================================================
// FIRESTORE SECURITY RULES — ServView
// =============================================================================
// Model:
//   • services / testimonials  — world-readable (public site), admin-only writes.
//   • enquiries                — anyone may CREATE a lead from the website, but
//                                only an admin may read/update/delete them.
// "admin" is a custom claim (admin == true) set once on the single admin account
// via the Firebase Admin SDK. There is no self-signup.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public catalog content — read by everyone, edited only by the admin.
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{id} {
      // Public read of all docs; the client shows only `approved == true`.
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leads. The website form may create; only the admin can see or manage them.
    match /enquiries/{id} {
      allow create: if isValidEnquiry();
      allow read, update, delete: if isAdmin();
    }

    function isValidEnquiry() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() < 200
        && d.phone is string && d.phone.size() > 0 && d.phone.size() < 40
        && d.status == 'new'
        && d.source is string;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
